SECRET_KEY=replace-with-strong-random-secret
MONGO_URI=replace-with-your-mongodb-connection-uri
MONGO_DB_NAME=bg_saas
SESSION_COOKIE_SECURE=true
USER_DAILY_USAGE_LIMIT=20
ADMIN_DAILY_USAGE_LIMIT=50
FAILED_ATTEMPTS_THRESHOLD=5
RATE_LIMIT_PER_MINUTE=30

# Optional startup bootstrap for admin role
ADMIN_USERNAME=replace-admin-username
ADMIN_PASSWORD=replace-admin-password

# Image Tiling (defaults)
TILE_SIZE=1024
TILE_OVERLAP=64

# PaddleOCR Text Detection
OCR_ENABLED=true
OCR_CONFIDENCE_THRESHOLD=0.5

# Mask Fusion Strategy (or | add | birefnet)
MASK_FUSION_STRATEGY=or

# Performance
PARALLEL_TILE_PROCESSING=false
MAX_IMAGE_RESOLUTION=4096
