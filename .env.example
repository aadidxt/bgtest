SECRET_KEY=replace-with-strong-random-secret
RATE_LIMIT_PER_MINUTE=30

# Image Tiling (defaults)
TILE_SIZE=1024
TILE_OVERLAP=64

# PaddleOCR Text Detection
OCR_ENABLED=true
OCR_CONFIDENCE_THRESHOLD=0.5

# Mask Fusion Strategy (or | add | birefnet)
MASK_FUSION_STRATEGY=or

# Performance
PARALLEL_TILE_PROCESSING=false
MAX_IMAGE_RESOLUTION=4096
